# Copy this file to .env and fill in real values.

# --- Server ---
PORT=3300
NODE_ENV=development
# When deployed behind Nginx at tool.selinnaowen.com/split-bill, set:
BASE_PATH=/split-bill

# --- Session ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=dev-secret-change-me

# --- LINE Login ---
# No longer used directly by this app — login is handled by the shared auth
# service at /auth/login. Keep these in the LINE Developers
# Console (the channel still works). You can remove them from this file
# once you're confident the SSO setup is working.
# LINE_LOGIN_CHANNEL_ID=
# LINE_LOGIN_CHANNEL_SECRET=

# --- Database ---
DB_PATH=/home/ubuntu/apps/split-bill/db/split-bill.db

# --- SSO (shared auth service) ---
# Server-to-server URL used to validate the shared luru_session cookie.
AUTH_SERVICE_INTERNAL_URL=http://127.0.0.1:3002/auth/api/session
# Public base path used to build login redirects for unauthenticated visitors.
AUTH_SERVICE_BASE=/auth
