# Copy this file to .env and fill in real values.

# --- Server ---
PORT=3300
NODE_ENV=development
# When deployed behind Nginx at tool.selinnaowen.com/split-bill, set:
# BASE_PATH=/split-bill
BASE_PATH=

# --- Session ---
# Generate a real random secret for production, e.g.: openssl rand -hex 32
SESSION_SECRET=dev-secret-change-me

# --- LINE Login ---
# From https://developers.line.biz/console/ -> your LINE Login channel
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# --- Database ---
# Defaults to db/split-bill.db if not set
DB_PATH=
