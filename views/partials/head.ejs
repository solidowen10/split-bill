<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>lürú | <%= typeof title !== 'undefined' ? title : 'Shared Ledger' %></title>
  <link rel="icon" href="https://www.selinnaowen.com/wp-content/uploads/2026/06/tools-logo-1.png">
  <link rel="apple-touch-icon" href="https://www.selinnaowen.com/wp-content/uploads/2026/06/tools-logo-1.png">
  <link rel="stylesheet" href="<%= basePath %>/static/css/style.css">
  <style>
    /* ── Shared shell styles (header / footer / menu) ── */
    :root {
      --font-seasons: "The Seasons", "The Seasons Regular", "The Seasons Light", Georgia, serif;
      --shell-accent: #7C6FAB; /* soft violet for Shared Ledger */
    }

    .luru-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #fff;
      border-bottom: 1px solid var(--line);
      padding: 0 28px;
      min-height: 74px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .luru-brand {
      display: flex;
      align-items: center;
      gap: 18px;
      text-decoration: none;
      color: inherit;
    }

    .luru-brand img {
      height: 26px;
      width: auto;
    }

    .luru-app-name {
      font-family: var(--font-seasons);
      font-size: clamp(28px, 3.1vw, 40px);
      font-weight: 650;
      color: #171B20;
      line-height: 1;
      letter-spacing: 0;
      white-space: nowrap;
    }

    .luru-app-name em {
      color: var(--shell-accent);
      font-style: italic;
    }

    @media (max-width: 520px) {
      .luru-header {
        min-height: 62px;
        padding: 0 14px;
      }

      .luru-brand {
        gap: 10px;
      }

      .luru-app-name {
        max-width: 58vw;
        overflow: hidden;
        font-size: 24px;
        text-overflow: ellipsis;
      }
    }

    /* ── Hamburger menu ── */
    .luru-menu {
      position: relative;
    }

    .luru-menu-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px 8px;
      color: #555;
      font-size: 20px;
      line-height: 1;
      border-radius: 6px;
      transition: background 0.15s;
    }

    .luru-menu-btn:hover {
      background: var(--surface, #f5f4f2);
    }

    .luru-menu-dropdown {
      display: none;
      position: absolute;
      right: 0;
      top: calc(100% + 8px);
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      padding: 8px;
      min-width: 200px;
      z-index: 200;
    }

    .luru-menu-dropdown.open {
      display: block;
    }

    .luru-menu-section-label {
      font-family: var(--font-seasons);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #aaa;
      padding: 8px 12px 4px;
    }

    .luru-menu-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 8px;
      text-decoration: none;
      color: #333;
      font-family: var(--font-seasons);
      font-size: 14px;
      font-weight: 500;
      transition: background 0.12s;
    }

    .luru-menu-item:hover {
      background: var(--surface, #f5f4f2);
      color: #111;
    }

    .luru-menu-item .menu-icon {
      font-size: 16px;
      width: 20px;
      text-align: center;
    }

    .luru-menu-divider {
      border: none;
      border-top: 1px solid var(--line);
      margin: 6px 0;
    }

    .luru-menu-item.logout {
      color: #888;
      font-weight: 400;
    }

    .luru-menu-item.logout:hover {
      color: #c0392b;
      background: #fff5f5;
    }

    /* ── Footer ── */
    .luru-footer {
      margin-top: 64px;
      padding: 28px 20px 32px;
      border-top: 1px solid var(--line);
      text-align: center;
    }

    .luru-footer-tagline {
      font-family: var(--font-seasons);
      font-size: 13px;
      color: #aaa;
      margin: 0 0 8px;
    }

    .luru-footer-link {
      font-family: var(--font-seasons);
      font-size: 14px;
      font-weight: 500;
      color: var(--shell-accent);
      text-decoration: none;
      letter-spacing: 0.01em;
    }

    .luru-footer-link:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

<header class="luru-header">
  <a href="<%= basePath %>/my-groups" class="luru-brand">
    <img src="https://www.selinnaowen.com/wp-content/uploads/2026/06/tools-logo-1.png" alt="lürú tools">
    <span class="luru-app-name">Shared <em>Ledger</em></span>
  </a>

  <div class="luru-menu">
    <button class="luru-menu-btn" id="luru-menu-toggle" aria-label="Open menu" aria-expanded="false">☰</button>
    <div class="luru-menu-dropdown" id="luru-menu-dropdown" role="menu">

      <div class="luru-menu-section-label">This app</div>
      <a href="<%= basePath %>/my-groups" class="luru-menu-item" role="menuitem">
        <span class="menu-icon">👥</span> My Groups
      </a>
      <a href="<%= basePath %>/" class="luru-menu-item" role="menuitem">
        <span class="menu-icon">➕</span> Create Group
      </a>

      <hr class="luru-menu-divider">
      <div class="luru-menu-section-label">Other tools</div>
      <a href="https://tool.selinnaowen.com/spending-tracker" class="luru-menu-item" role="menuitem">
        <span class="menu-icon">💰</span> Spending Tracker
      </a>
      <a href="https://tool.selinnaowen.com/lifestyle-tracker" class="luru-menu-item" role="menuitem">
        <span class="menu-icon">🌟</span> Lifestyle Tracker
      </a>
      <a href="https://tool.selinnaowen.com/" class="luru-menu-item" role="menuitem">
        <span class="menu-icon">🏠</span> All Tools
      </a>

      <hr class="luru-menu-divider">
      <a href="<%= basePath %>/logout" class="luru-menu-item logout" role="menuitem">
        <span class="menu-icon">↩︎</span> Log out
      </a>
    </div>
  </div>
</header>

<div class="wrap">

<script>
(function() {
  var btn = document.getElementById('luru-menu-toggle');
  var drop = document.getElementById('luru-menu-dropdown');
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    var open = drop.classList.toggle('open');
    btn.setAttribute('aria-expanded', open);
  });
  document.addEventListener('click', function() {
    drop.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  });
  drop.addEventListener('click', function(e) { e.stopPropagation(); });
})();
</script>
