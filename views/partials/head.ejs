  <details class="menu">
    <summary style="list-style:none; cursor:pointer; font-size:24px; line-height:1;">☰</summary>
    <div style="position:absolute; right:20px; margin-top:10px; background:white; border:1px solid var(--line); border-radius:10px; box-shadow:var(--shadow-card); padding:10px; min-width:180px; z-index:10;">
      <a href="<%= basePath %>/my-groups" style="display:block; padding:10px; color:inherit;">My Groups</a>
      <a href="<%= basePath %>/" style="display:block; padding:10px; color:inherit;">Create Group</a>
      <a href="https://tool.selinnaowen.com/" style="display:block; padding:10px; color:inherit;">All Tools</a>
      <hr style="border:0; border-top:1px solid var(--line); margin:8px 0;">

      <a href="<%= basePath %>/logout" style="display:block; padding:10px; color:inherit;">
        Log out
      </a>
    </div>
