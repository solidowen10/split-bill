<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>lürú | Shared Ledger</title>
  <link rel="stylesheet" href="<%= basePath %>/static/css/style.css">
  <link rel="icon" href="https://www.selinnaowen.com/wp-content/uploads/2026/06/tools-logo-1.png">
  <link rel="apple-touch-icon" href="https://www.selinnaowen.com/wp-content/uploads/2026/06/tools-logo-1.png">
</head>
<body>
<div class="wrap">
  <div class="brand" style="display:flex; align-items:center; justify-content:space-between;">
  <a href="<%= basePath %>/my-groups" style="text-decoration:none; color:inherit; display:flex; align-items:center; gap:10px;">
    <img src="https://www.selinnaowen.com/wp-content/uploads/2026/06/tools-logo-1.png" alt="Selinna Owen Tools" style="height:28px; width:auto;">
    <span class="mark">Shared <em>Ledger</em></span>
